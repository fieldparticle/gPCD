       float var_1 = V * ( 1 - S );
       float var_2 = V * ( 1 - S * ( var_h - var_i ) );
       float var_3 = V * ( 1 - S * ( 1 - ( var_h - var_i ) ) );

       if( var_i == 0 )
       {
            var_r = V;
            var_g = var_3 ;
            var_b = var_1;
        }
       else if ( var_i == 1 )
       {
            var_r = var_2 ;
            var_g = V     ;
            var_b = var_1;
        }
       else if ( var_i == 2 )
       {
            var_r = var_1 ;
            var_g = V     ;
            var_b = var_3 ;
        }
       else if ( var_i == 3 )
       {
            var_r = var_1 ;
            var_g = var_2 ;
            var_b = V ;
        }
       else if ( var_i == 4 )
       {
            var_r = var_3 ;
            var_g = var_1 ;
            var_b = V;
        }
       else
       {
            var_r = V     ;
            var_g = var_1 ;
            var_b = var_2 ;
        };

       R = var_r * 255;
       G = var_g * 255;
       B = var_b * 255;
    }
    ret_clr = vec3(R/255,G/255,B/255);
    return ret_clr;
}

