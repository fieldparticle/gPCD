digraph ShadowProposedSystemFlow {
  graph [
    rankdir=TB,
    compound=true,
    bgcolor="white",
    fontname="Consolas",
    fontsize=11
  ];
  node [
    fontname="Consolas",
    fontsize=10,
    style="rounded,filled",
    color="#606060"
  ];
  edge [
    fontname="Consolas",
    fontsize=9,
    color="#505050"
  ];

  subgraph cluster_frame {
    label="Frame Inputs";
    color="#c8c8c8";
    style="rounded";
    Start [label="Start Frame", shape=oval, fillcolor="#eaf8ea"];
    Snapshot [label="Build frame snapshot", shape=box, fillcolor="#f8f8f8"];
    SnapshotData [label="snapshot positions / velocities", shape=cylinder, fillcolor="#eaf3ff"];
  }
  subgraph cluster_detect {
    label="Pass 1: Detect and Store Geometry";
    color="#c8c8c8";
    style="rounded";
    DetectLoop [label="source-target scan", shape=box, fillcolor="#f8f8f8"];
    Contact [label="contact?", shape=diamond, fillcolor="#fff6d8"];
    StoreGeometry [label="store directed contact geometry", shape=box, fillcolor="#f8f8f8"];
    ContactData [label="contact slots: target, normal, area, distance", shape=cylinder, fillcolor="#eaf3ff"];
  }
  subgraph cluster_context {
    label="Pass 2: Build Source Context";
    color="#c8c8c8";
    style="rounded";
    SourceContextLoop [label="for each source contact list", shape=box, fillcolor="#f8f8f8"];
    HasContacts [label="has contacts?", shape=diamond, fillcolor="#fff6d8"];
    BuildContext [label="sum overlap and closing momentum", shape=box, fillcolor="#f8f8f8"];
    ContextData [label="source context: total area, available momentum", shape=cylinder, fillcolor="#eaf3ff"];
  }
  subgraph cluster_allocation {
    label="Pass 3: Plan Source Allocation";
    color="#c8c8c8";
    style="rounded";
    AllocationLoop [label="for each source contact list", shape=box, fillcolor="#f8f8f8"];
    SourceTarget [label="compute source-level target", shape=box, fillcolor="#f8f8f8"];
    Distribute [label="distribute target by contact weights", shape=box, fillcolor="#f8f8f8"];
    CandidateData [label="directed candidates", shape=cylinder, fillcolor="#eaf3ff"];
  }
  subgraph cluster_pair_plan {
    label="Pass 4: Pair Compatibility";
    color="#c8c8c8";
    style="rounded";
    PairLoop [label="for each unordered pair", shape=box, fillcolor="#f8f8f8"];
    PairCompatible [label="choose compatible pair impulse", shape=box, fillcolor="#f8f8f8"];
    PlanData [label="planned directed impulses", shape=cylinder, fillcolor="#eaf3ff"];
  }
  subgraph cluster_apply {
    label="Pass 5: Apply Source-Owned Writes";
    color="#c8c8c8";
    style="rounded";
    ApplyLoop [label="for each source", shape=box, fillcolor="#f8f8f8"];
    ReadPlan [label="read planned impulses", shape=box, fillcolor="#f8f8f8"];
    VectorSum [label="sum vector impulse delta", shape=box, fillcolor="#f8f8f8"];
    WriteSource [label="write source velocity only", shape=box, fillcolor="#f8f8f8"];
    UpdateLedgers [label="update source-owned ledgers", shape=box, fillcolor="#f8f8f8"];
  }
  subgraph cluster_move {
    label="Pass 6: Move";
    color="#c8c8c8";
    style="rounded";
    Move [label="move particles", shape=box, fillcolor="#f8f8f8"];
    End [label="End Frame", shape=oval, fillcolor="#eaf8ea"];
  }

    Start -> Snapshot;
    Snapshot -> SnapshotData [label="write"];
    SnapshotData -> DetectLoop [label="read"];
    DetectLoop -> Contact;
    Contact -> StoreGeometry [label="yes"];
    Contact -> DetectLoop [label="no / next pair"];
    StoreGeometry -> ContactData [label="write"];
    ContactData -> DetectLoop [label="next pair"];
    DetectLoop -> SourceContextLoop [label="scan done"];
    SourceContextLoop -> HasContacts;
    HasContacts -> BuildContext [label="yes"];
    HasContacts -> SourceContextLoop [label="no / next source"];
    BuildContext -> ContextData [label="write"];
    ContextData -> SourceContextLoop [label="next source"];
    SourceContextLoop -> AllocationLoop [label="contexts done"];
    AllocationLoop -> SourceTarget;
    SourceTarget -> Distribute;
    Distribute -> CandidateData [label="write"];
    CandidateData -> AllocationLoop [label="next source"];
    AllocationLoop -> PairLoop [label="allocation done"];
    PairLoop -> PairCompatible;
    PairCompatible -> PlanData [label="write"];
    PlanData -> PairLoop [label="next pair"];
    PairLoop -> ApplyLoop [label="plan done"];
    ApplyLoop -> ReadPlan;
    ReadPlan -> VectorSum;
    VectorSum -> WriteSource;
    WriteSource -> UpdateLedgers;
    UpdateLedgers -> ApplyLoop [label="next source"];
    ApplyLoop -> Move [label="all sources done"];
    Move -> End;
}
