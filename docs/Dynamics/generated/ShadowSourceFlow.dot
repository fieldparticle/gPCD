digraph ShadowSourceFlow {
  graph [
    rankdir=TB,
    compound=true,
    bgcolor="white",
    fontname="Consolas",
    fontsize=11
  ];
  node [
    fontname="Consolas",
    fontsize=10,
    style="rounded,filled",
    fillcolor="#f8f8f8",
    color="#606060"
  ];
  edge [
    fontname="Consolas",
    fontsize=9,
    color="#505050"
  ];

  subgraph cluster_setup {
    label="Frame Setup";
    color="#c8c8c8";
    style="rounded";
    CollisionRun [label="CollisionRun", shape=oval, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:265:1", tooltip="Open CollisionRun in VS Code", target="_blank"];
    GeoBeginFrame [label="GeoBeginFrame", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:349:1", tooltip="Open GeoBeginFrame in VS Code", target="_blank"];
    GeoApplyBeforeContactScanHook [label="GeoApplyBeforeContactScanHook", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:364:1", tooltip="Open GeoApplyBeforeContactScanHook in VS Code", target="_blank"];
    GeoResetFrameState [label="GeoResetFrameState", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:377:1", tooltip="Open GeoResetFrameState in VS Code", target="_blank"];
    GeoApplyStartRunHook [label="GeoApplyStartRunHook", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:414:1", tooltip="Open GeoApplyStartRunHook in VS Code", target="_blank"];
    GeoBuildFrameSnapshot [label="GeoBuildFrameSnapshot", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:427:1", tooltip="Open GeoBuildFrameSnapshot in VS Code", target="_blank"];
    GeoRecordFrameStartDiagnostics [label="GeoRecordFrameStartDiagnostics", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:475:1", tooltip="Open GeoRecordFrameStartDiagnostics in VS Code", target="_blank"];
  }
  subgraph cluster_detect {
    label="Contact Detection";
    color="#c8c8c8";
    style="rounded";
    GeoDetectContact [label="GeoDetectContact", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:496:1", tooltip="Open GeoDetectContact in VS Code", target="_blank"];
    isParticleContact [label="isParticleContact", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:578:1", tooltip="Open isParticleContact in VS Code", target="_blank"];
    GeoAddParticleContact [label="GeoAddParticleContact", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:705:1", tooltip="Open GeoAddParticleContact in VS Code", target="_blank"];
  }
  subgraph cluster_planning {
    label="Impulse Planning";
    color="#c8c8c8";
    style="rounded";
    GeoPlanContactImpulses [label="GeoPlanContactImpulses", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:655:1", tooltip="Open GeoPlanContactImpulses in VS Code", target="_blank"];
    GeoContactContext [label="GeoContactContext", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:292:1", tooltip="Open GeoContactContext in VS Code", target="_blank"];
    GeoCalculatePairContact [label="GeoCalculatePairContact", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:496:1", tooltip="Open GeoCalculatePairContact in VS Code", target="_blank"];
    GeoParticleGeometry [label="GeoParticleGeometry", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:245:1", tooltip="Open GeoParticleGeometry in VS Code", target="_blank"];
    GeoStartFrameVelocity [label="GeoStartFrameVelocity", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:286:1", tooltip="Open GeoStartFrameVelocity in VS Code", target="_blank"];
    GeoVelocityProgressImpulse [label="GeoVelocityProgressImpulse", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:350:1", tooltip="Open GeoVelocityProgressImpulse in VS Code", target="_blank"];
    GeoBuildPairCompatiblePlan [label="GeoBuildPairCompatiblePlan", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:616:1", tooltip="Open GeoBuildPairCompatiblePlan in VS Code", target="_blank"];
    GeoPlannedContactImpulses [label="GeoPlannedContactImpulses", shape=note];
  }
  subgraph cluster_resolve {
    label="Contact Resolution";
    color="#c8c8c8";
    style="rounded";
    GeoResolveContacts [label="GeoResolveContacts", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:532:1", tooltip="Open GeoResolveContacts in VS Code", target="_blank"];
    GeoProcessCollisions [label="GeoProcessCollisions", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowDynamics.py:769:1", tooltip="Open GeoProcessCollisions in VS Code", target="_blank"];
