  }
  subgraph cluster_motion {
    label="Motion / End Frame";
    color="#c8c8c8";
    style="rounded";
    GeoMoveParticles [label="GeoMoveParticles", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:545:1", tooltip="Open GeoMoveParticles in VS Code", target="_blank"];
    GeoEndFrame [label="GeoEndFrame", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:556:1", tooltip="Open GeoEndFrame in VS Code", target="_blank"];
  }
  subgraph cluster_common {
    label="Shared Helpers";
    color="#c8c8c8";
    style="rounded";
    particle_position [label="particle_position", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:573:1", tooltip="Open particle_position in VS Code", target="_blank"];
    particle_overlap_area [label="particle_overlap_area", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:615:1", tooltip="Open particle_overlap_area in VS Code", target="_blank"];
    GeoVelocityAngle [label="GeoVelocityAngle", shape=box, URL="vscode://file/C:/_DJ/gPCD/python/base/ShadowBase.py:117:1", tooltip="Open GeoVelocityAngle in VS Code", target="_blank"];
  }

    CollisionRun -> GeoBeginFrame;
    GeoBeginFrame -> GeoApplyBeforeContactScanHook;
    GeoApplyBeforeContactScanHook -> GeoResetFrameState;
    GeoResetFrameState -> GeoApplyStartRunHook;
    GeoApplyStartRunHook -> GeoBuildFrameSnapshot;
    GeoBuildFrameSnapshot -> GeoRecordFrameStartDiagnostics;
    GeoRecordFrameStartDiagnostics -> GeoDetectContact;
    GeoDetectContact -> GeoPlanContactImpulses;
    GeoPlanContactImpulses -> GeoResolveContacts;
    GeoResolveContacts -> GeoRecordAfterResolveDiagnostics;
    GeoRecordAfterResolveDiagnostics -> GeoMoveParticles;
    GeoMoveParticles -> GeoEndFrame;
    GeoDetectContact -> isParticleContact [label="detect"];
    isParticleContact -> particle_position [label="position"];
    isParticleContact -> particle_overlap_area [label="area"];
    GeoDetectContact -> GeoAddParticleContact [label="record"];
    GeoPlanContactImpulses -> GeoContactContext [label="source context"];
    GeoPlanContactImpulses -> GeoCalculatePairContact [label="per contact"];
    GeoCalculatePairContact -> GeoParticleGeometry [label="geometry"];
    GeoParticleGeometry -> particle_position [label="position"];
    GeoParticleGeometry -> particle_overlap_area [label="area"];
    GeoCalculatePairContact -> GeoStartFrameVelocity [label="snapshot velocity"];
    GeoCalculatePairContact -> GeoVelocityProgressImpulse [label="phase/impulse"];
    GeoPlanContactImpulses -> GeoBuildPairCompatiblePlan [label="pair reconcile"];
    GeoBuildPairCompatiblePlan -> GeoPlannedContactImpulses [label="store plan"];
    GeoResolveContacts -> GeoProcessCollisions [label="per source"];
    GeoProcessCollisions -> GeoPlannedContactImpulses [label="read plan"];
    GeoProcessCollisions -> GeoVelocityAngle [label="VelRad.w"];
}
