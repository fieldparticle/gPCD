digraph MomentumDynamicsFlow {
  graph [
    rankdir=TB,
    compound=true,
    bgcolor="white",
    fontname="Consolas",
    fontsize=11,
    splines=ortho,
    nodesep=0.75,
    ranksep=0.65
  ];
  node [
    fontname="Consolas",
    fontsize=10,
    style="rounded,filled",
    color="#606060"
  ];
  edge [
    fontname="Consolas",
    fontsize=9,
    color="#505050",
    arrowsize=0.7
  ];

    ContactDynamics [label="ContactDynamics", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:88:1", tooltip="Open the ContactDynamics section in SourceDocumentation.tex", target="_blank"];
    BeginSourceContactParms [label="BeginSourceContactParms", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:111:1", tooltip="Open the BeginSourceContactParms section in SourceDocumentation.tex", target="_blank"];
    InitializeContactState [label="InitializeContactState", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:124:1", tooltip="Open the InitializeContactState section in SourceDocumentation.tex", target="_blank"];
    GetContactState [label="GetContactState", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:132:1", tooltip="Open the GetContactState section in SourceDocumentation.tex", target="_blank"];
    GetParticleGeometry [label="GetParticleGeometry", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:177:1", tooltip="Open the GetParticleGeometry section in SourceDocumentation.tex", target="_blank"];
    GetParticlePosition [label="GetParticlePosition", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:192:1", tooltip="Open the GetParticlePosition section in SourceDocumentation.tex", target="_blank"];
    AppendContactSlot [label="AppendContactSlot", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:142:1", tooltip="Open the AppendContactSlot section in SourceDocumentation.tex", target="_blank"];
    GetContactSlots [label="GetContactSlots", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:158:1", tooltip="Open the GetContactSlots section in SourceDocumentation.tex", target="_blank"];
    GetCollisionPhase [label="GetCollisionPhase", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:165:1", tooltip="Open the GetCollisionPhase section in SourceDocumentation.tex", target="_blank"];
    GetCollisionInternalMomentum [label="GetCollisionInternalMomentum", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:171:1", tooltip="Open the GetCollisionInternalMomentum section in SourceDocumentation.tex", target="_blank"];
    CalculateContactParms [label="CalculateContactParms", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:199:1", tooltip="Open the CalculateContactParms section in SourceDocumentation.tex", target="_blank"];
    GetStartFrameVelocity [label="GetStartFrameVelocity", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:222:1", tooltip="Open the GetStartFrameVelocity section in SourceDocumentation.tex", target="_blank"];
    GetReducedMass [label="GetReducedMass", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:229:1", tooltip="Open the GetReducedMass section in SourceDocumentation.tex", target="_blank"];
    CalculateContactImpulse [label="CalculateContactImpulse", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:1:1", tooltip="Open the CalculateContactImpulse section in SourceDocumentation.tex", target="_blank"];
    GetPairStiffness [label="GetPairStiffness", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:285:1", tooltip="Open the GetPairStiffness section in SourceDocumentation.tex", target="_blank"];
    ApplySourceMomentumDelta [label="ApplySourceMomentumDelta", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:1:1", tooltip="Open the ApplySourceMomentumDelta section in SourceDocumentation.tex", target="_blank"];
    GetParticleMass [label="GetParticleMass", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:316:1", tooltip="Open the GetParticleMass section in SourceDocumentation.tex", target="_blank"];
    UpdateContactLedgers [label="UpdateContactLedgers", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:321:1", tooltip="Open the UpdateContactLedgers section in SourceDocumentation.tex", target="_blank"];
    SetCollisionInternalMomentum [label="SetCollisionInternalMomentum", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:339:1", tooltip="Open the SetCollisionInternalMomentum section in SourceDocumentation.tex", target="_blank"];
    SetCollisionPhase [label="SetCollisionPhase", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:345:1", tooltip="Open the SetCollisionPhase section in SourceDocumentation.tex", target="_blank"];
    SyncInternalMomentum [label="SyncInternalMomentum", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:351:1", tooltip="Open the SyncInternalMomentum section in SourceDocumentation.tex", target="_blank"];
    GetInternalMomentum [label="GetInternalMomentum", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:357:1", tooltip="Open the GetInternalMomentum section in SourceDocumentation.tex", target="_blank"];
    SetInternalMomentum [label="SetInternalMomentum", shape=box, fillcolor="#f8f8f8", URL="vscode://file/C:/_DJ/gPCD/docs/Dynamics/SourceDocumentation.tex:363:1", tooltip="Open the SetInternalMomentum section in SourceDocumentation.tex", target="_blank"];

  {
    rank=same;
    ContactDynamics;
    ApplySourceMomentumDelta;
  }

    ContactDynamics -> BeginSourceContactParms;
    BeginSourceContactParms -> InitializeContactState [label="first contact"];
    InitializeContactState -> GetContactState;
    GetContactState -> AppendContactSlot;
    AppendContactSlot -> GetContactSlots;
    GetContactSlots -> GetCollisionPhase;
    GetCollisionPhase -> GetCollisionInternalMomentum;
    GetCollisionInternalMomentum -> GetParticleGeometry;
    GetParticleGeometry -> GetParticlePosition;
    GetParticlePosition -> GetStartFrameVelocity;
    GetStartFrameVelocity -> GetReducedMass;
    GetReducedMass -> CalculateContactParms;
    CalculateContactParms -> CalculateContactImpulse;
    CalculateContactImpulse -> GetPairStiffness;
    GetPairStiffness -> CalculateContactImpulse;
    CalculateContactImpulse -> InitializeContactState [label="next contact"];
    CalculateContactImpulse -> ApplySourceMomentumDelta [label="all contacts done"];
    ApplySourceMomentumDelta -> GetParticleMass;
    GetParticleMass -> ApplySourceMomentumDelta;
    ApplySourceMomentumDelta -> UpdateContactLedgers;
    UpdateContactLedgers -> SetCollisionInternalMomentum;
    SetCollisionInternalMomentum -> SetCollisionPhase;
    SetCollisionPhase -> SyncInternalMomentum;
    SyncInternalMomentum -> GetInternalMomentum;
    GetInternalMomentum -> SetInternalMomentum;
}
