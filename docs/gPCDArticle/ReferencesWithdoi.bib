  title = {Bulk Flow Modification with Horseshoe and Serpentine Plasma Actuators},
  author = {Roy, Subrata and Wang, Chin-Cheng},
  year = 2009,
  month = feb,
  journal = {Journal of Physics D: Applied Physics},
  volume = {42},
  number = {3},
  pages = {032004},
  issn = {0022-3727, 1361-6463},
  doi = {10.1088/0022-3727/42/3/032004},
