  author = {Teschner, M. and Kimmerle, S. and Heidelberger, B. and Zachmann, G. and Raghupathi, L. and Fuhrmann, A. and Cani, M.-P. and Faure, F. and {Magnenat-Thalmann}, N. and Strasser, W. and Volino, P.},
