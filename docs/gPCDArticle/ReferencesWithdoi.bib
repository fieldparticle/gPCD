  pages = {75--86},
  issn = {02632241},
  doi = {10.1016/S0263-2241(97)00069-9},
  urldate = {2024-11-30},
  abstract = {The use of constant-temperature anemometry for measurements in flows characterized by temperature drifts and fluctuations is difficult because of the dependence of the anemometer response on the temperature of the medium. Methods of combating this problem generally fall into one of several categories in terms of correction methodology. These methodologies include electronic correction, mathematical correction, manual adjustment of the hot resistance, and direct velocity and temperature calibration. This paper examines the random errors associated with mathematical correction of the anemometer signal and assesses the significance of these errors relative to other errors associated with using a constant-temperature anemometer for velocity and/or turbulence measurements. \copyright{} 1998 Elsevier Science Ltd.},
  langid = {english}
}

